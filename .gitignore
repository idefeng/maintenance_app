# Python 运行缓存
tools/**/__pycache__/

# 文件整理工具运行产物
tools/file_organizer/runtime/logs/
tools/file_organizer/runtime/reports/
tools/file_organizer/runtime/config/

# 应用残留扫描工具运行产物
tools/app_cleanup/runtime/logs/
tools/app_cleanup/runtime/reports/

# 磁盘空间清理工具运行产物
tools/disk_cleanup/runtime/logs/*
tools/disk_cleanup/runtime/reports/*
!tools/disk_cleanup/runtime/logs/.gitkeep
!tools/disk_cleanup/runtime/reports/.gitkeep

# SwiftPM 构建产物
tools/maintenance_app/.build/
tools/maintenance_app/dist/
